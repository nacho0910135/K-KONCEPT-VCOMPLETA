generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TECHNICIAN
  CLIENT
  SYSTEM
}

enum TicketStatus {
  OPEN
  PENDING
  IN_PROGRESS
  WAITING_CUSTOMER
  RESOLVED
  CLOSED
  CANCELLED
  REOPENED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CloseType {
  WITH_SOLUTION
  WITHOUT_SOLUTION
  REPLACEMENT
}

enum ReplacementStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  IN_TRANSIT
  DELIVERED
}

enum AppointmentStatus {
  SCHEDULED
  RESCHEDULED
  COMPLETED
  CANCELLED
}

enum WarrantyStatus {
  VALID
  EXPIRED
  NOT_APPLICABLE
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationEvent {
  TICKET_CREATED
  TICKET_ASSIGNED
  STATUS_CHANGED
  NEW_COMMENT
  TICKET_RESOLVED
  TICKET_CLOSED
  APPOINTMENT_RESCHEDULED
  REPLACEMENT_APPROVED
  SLA_BREACH
}

enum FileType {
  IMAGE
  VIDEO
  PDF
  DOCUMENT
}

model User {
  id                         String            @id @default(uuid())
  name                       String
  email                      String            @unique
  password                   String
  role                       Role              @default(CLIENT)
  phone                      String?
  company                    String?
  active                     Boolean           @default(true)
  lastLogin                  DateTime?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt

  warranties                 Warranty[]        @relation("ClientWarranties")
  clientTickets              Ticket[]          @relation("ClientTickets")
  assignedTickets            Ticket[]          @relation("AssignedTechnicianTickets")
  changedStatusHistories     TicketStatusHistory[] @relation("TicketStatusChangedBy")
  comments                   TicketComment[]
  evidenceUploads            TicketEvidence[]  @relation("EvidenceUploadedBy")
  requestedReplacements      Replacement[]     @relation("ReplacementRequestedBy")
  approvedReplacements       Replacement[]     @relation("ReplacementApprovedBy")
  deliveredReplacements      Replacement[]     @relation("ReplacementDeliveredBy")
  technicianAppointments     Appointment[]     @relation("AppointmentTechnician")
  createdAppointments        Appointment[]     @relation("AppointmentCreatedBy")
  clientSlas                 Sla[]             @relation("ClientSlas")
  notifications              Notification[]
  auditLogs                  AuditLog[]
  scheduledReports           ScheduledReport[]
  refreshTokens              RefreshToken[]
  passwordResetCodes         PasswordResetCode[]

  @@index([role, active])
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  description   String?
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  subcategories Subcategory[]
  products      Product[]
  tickets       Ticket[]
  slas          Sla[]
}

model Subcategory {
  id          String    @id @default(uuid())
  name        String
  description String?
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tickets     Ticket[]

  @@unique([name, categoryId])
  @@index([categoryId])
}

model TicketCounter {
  id        String   @id
  count     Int      @default(0)
  year      Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("TicketCounters")
}

model Product {
  id                        String        @id @default(uuid())
  name                      String
  brand                     String?
  model                     String?
  serialNumber              String        @unique
  categoryId                String?
  category                  Category?     @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  description               String?
  purchaseDate              DateTime?
  active                    Boolean       @default(true)
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  warranties                Warranty[]
  tickets                   Ticket[]
  replacementProductEntries Replacement[] @relation("ReplacementProduct")

  @@index([categoryId])
  @@index([brand, model])
}

model Warranty {
  id        String         @id @default(uuid())
  productId String
  product   Product        @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  clientId  String
  client    User           @relation("ClientWarranties", fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  status    WarrantyStatus @default(VALID)
  startDate DateTime
  endDate   DateTime
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  tickets   Ticket[]

  @@index([productId, clientId])
  @@index([clientId])
}

model Ticket {
  id                   String       @id @default(uuid())
  code                 String       @unique
  title                String
  description          String
  status               TicketStatus @default(OPEN)
  priority             Priority     @default(MEDIUM)
  categoryId           String
  category             Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  subcategoryId        String?
  subcategory          Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  clientId             String
  client               User         @relation("ClientTickets", fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  assignedTechnicianId String?
  assignedTechnician   User?        @relation("AssignedTechnicianTickets", fields: [assignedTechnicianId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  productId            String?
  product              Product?     @relation(fields: [productId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  warrantyId           String?
  warranty             Warranty?    @relation(fields: [warrantyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  warrantyStatusAtCreation WarrantyStatus?
  warrantyWarning      String?
  diagnosis            String?
  solution             String?
  closeType            CloseType?
  closeJustification   String?
  /// Validar en service: valor entre 1 y 5.
  rating               Int?
  ratingComment        String?
  slaId                String?
  sla                  Sla?         @relation(fields: [slaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  slaDeadline          DateTime?
  /// Validar en service: "CLIENT", "CATEGORY" o "PRIORITY".
  slaSource            String?
  slaBreached          Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  statusHistories      TicketStatusHistory[]
  comments             TicketComment[]
  evidence             TicketEvidence[]
  replacements         Replacement[]
  appointments         Appointment[]

  @@index([status, priority])
  @@index([clientId])
  @@index([assignedTechnicianId])
  @@index([slaDeadline])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([productId])
  @@index([warrantyId])
}

model TicketStatusHistory {
  /// Tabla append-only: no permitir UPDATE ni DELETE desde la capa de aplicacion.
  id             String        @id @default(uuid())
  ticketId       String
  ticket         Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  previousStatus TicketStatus?
  newStatus      TicketStatus
  changedById    String
  changedBy      User          @relation("TicketStatusChangedBy", fields: [changedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  comment        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([ticketId])
  @@index([changedById])
  @@index([newStatus])
}

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  comment    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ticketId])
  @@index([userId])
}

model TicketEvidence {
  id           String   @id @default(uuid())
  ticketId     String
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  uploadedById String
  uploadedBy   User     @relation("EvidenceUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  fileUrl      String
  fileType     FileType
  publicId     String
  fileName     String
  fileSize     Int
  mimeType     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ticketId])
  @@index([uploadedById])
  @@index([fileType])
}

model Replacement {
  id                       String            @id @default(uuid())
  ticketId                 String
  ticket                   Ticket            @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  requestedById            String
  requestedBy              User              @relation("ReplacementRequestedBy", fields: [requestedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reason                   String
  status                   ReplacementStatus @default(PENDING_APPROVAL)
  approvedById             String?
  approvedBy               User?             @relation("ReplacementApprovedBy", fields: [approvedById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  validationNotes          String?
  validatedAt              DateTime?
  requestedProduct         String
  replacementProductId     String?
  replacementProduct       Product?          @relation("ReplacementProduct", fields: [replacementProductId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  replacementSerialNumber  String?
  replacementBrand         String?
  replacementModel         String?
  replacementNotes         String?
  deliveryDate             DateTime?
  deliveredById            String?
  deliveredBy              User?             @relation("ReplacementDeliveredBy", fields: [deliveredById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  deliveryObservations     String?
  pdfUrl                   String?
  pdfPublicId              String?
  pdfGeneratedAt           DateTime?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  @@index([ticketId])
  @@index([requestedById])
  @@index([approvedById])
  @@index([deliveredById])
  @@index([status])
}

model Appointment {
  id               String            @id @default(uuid())
  ticketId         String
  ticket           Ticket            @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  technicianId     String
  technician       User              @relation("AppointmentTechnician", fields: [technicianId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  appointmentDate  DateTime
  status           AppointmentStatus @default(SCHEDULED)
  reason           String
  originalDate     DateTime?
  rescheduleReason String?
  createdById      String
  createdBy        User              @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([ticketId])
  @@index([technicianId, appointmentDate])
  @@index([status])
}

model Sla {
  /// Validar en service: al menos uno de priority, categoryId o clientId debe estar presente.
  id                 String    @id @default(uuid())
  name               String
  version            Int       @default(1)
  priority           Priority?
  categoryId         String?
  category           Category? @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  clientId           String?
  client             User?     @relation("ClientSlas", fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  maxResolutionHours Int
  maxResponseHours   Int
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tickets            Ticket[]

  @@index([priority])
  @@index([categoryId])
  @@index([clientId])
  @@index([active])
}

model Notification {
  id         String              @id @default(uuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  title      String
  message    String
  event      NotificationEvent
  entityType String
  entityId   String
  channel    NotificationChannel
  read       Boolean             @default(false)
  sentAt     DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([userId, read])
  @@index([event])
  @@index([entityType, entityId])
}

model NotificationTemplate {
  id           String              @id @default(uuid())
  event        NotificationEvent
  channel      NotificationChannel
  subject      String?
  bodyTemplate String
  active       Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([event, channel])
  @@index([active])
}

model NotificationChannelsConfig {
  id        String              @id @default(uuid())
  channel   NotificationChannel @unique
  enabled   Boolean             @default(true)
  config    Json
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model NotificationFrequencyRule {
  id                String            @id @default(uuid())
  event             NotificationEvent @unique
  maxPerUserPerHour Int
  maxPerUserPerDay  Int
  active            Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model AuditLog {
  /// Tabla append-only: no permitir UPDATE ni DELETE desde la capa de aplicacion.
  id            String   @id @default(uuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  action        String
  entity        String
  entityId      String?
  previousValue Json?
  newValue      Json?
  ipAddress     String?
  userAgent     String?
  result        String
  details       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId])
}

model ScheduledReport {
  id             String   @id @default(uuid())
  name           String
  reportType     String
  parameters     Json
  frequency      String
  cronExpression String
  recipients     String[]
  format         String
  active         Boolean  @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([active, nextRunAt])
  @@index([createdById])
  @@index([reportType])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  tokenHash String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

model PasswordResetCode {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([codeHash])
  @@index([expiresAt])
  @@index([usedAt])
}

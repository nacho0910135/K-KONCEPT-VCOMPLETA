# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api

# CORS
# Comma-separated whitelist. Example: http://localhost:3000,https://app.kollabkoncepts.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL / Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kollab_koncepts_reports?schema=public"

# JWT
JWT_SECRET="change-me-with-a-strong-secret"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Initial seed users
ADMIN_INITIAL_PASSWORD="ChangeMe.Admin.2026!"
SYSTEM_INITIAL_PASSWORD="system-account-disabled"

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Kollab Koncepts <no-reply@kollabkoncepts.com>"

# Cron Jobs
ENABLE_CRON_JOBS=true
TICKET_CLEANUP_CRON="0 3 * * *"
SLA_CHECK_CRON="*/15 * * * *"
SCHEDULED_REPORTS_CRON="0 * * * *"

# Ticket policy
BLOCK_TICKET_WITHOUT_WARRANTY=false

# Appointment scheduling
APPOINTMENT_SLOT_MINUTES=60
WORK_START_HOUR=8
WORK_END_HOUR=18
WORK_DAYS=1,2,3,4,5
